# Huly Self-Host for Coolify - huly.smenode.com
# Copy these values into Coolify > Environment Variables > Developer View.
# This version uses Docker named volumes, so no SSH mkdir/chown step is required.
# Generate strong secrets with: openssl rand -hex 32

DOCKER_NAME=huly

# Pin production Huly image versions. Keep DESKTOP_CHANNEL in sync without the leading "v".
HULY_VERSION=v0.7.423
DESKTOP_CHANNEL=0.7.423

# Public domain behind Coolify HTTPS reverse proxy.
HOST_ADDRESS=huly.smenode.com
SECURE=true
TITLE=Huly - SMEnode
DEFAULT_LANGUAGE=en
LAST_NAME_FIRST=true

# Kept for compatibility with Huly variables. nginx is exposed internally on port 80 for Coolify.
HTTP_BIND=0.0.0.0
HTTP_PORT=8087

# CockroachDB
CR_DATABASE=defaultdb
CR_USERNAME=selfhost
CR_USER_PASSWORD=CHANGE_ME_STRONG_COCKROACH_PASSWORD
# IMPORTANT: The password in CR_DB_URL must match CR_USER_PASSWORD exactly.
CR_DB_URL=postgresql://selfhost:CHANGE_ME_STRONG_COCKROACH_PASSWORD@cockroach:26257/defaultdb?sslmode=disable

# Redpanda admin user used by the healthcheck.
REDPANDA_ADMIN_USER=superadmin
REDPANDA_ADMIN_PWD=CHANGE_ME_STRONG_REDPANDA_PASSWORD

# Huly application secret.
SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Do NOT set VOLUME_*_PATH variables for this Coolify-friendly version.
# Leaving them unset makes Docker/Coolify create named volumes automatically:
# elastic, files, cr_data, cr_certs, redpanda, mongodb
